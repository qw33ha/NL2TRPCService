name: build-and-deploy

on:
  push:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - uses: actions/setup-go@v6
        with:
          go-version: "1.22"
      - run: go mod tidy
      - run: go test ./...
      - run: go build ./...

  docker:
    needs: build
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: write
    outputs:
      image: ${{ '{{' }} steps.image.outputs.reference {{ '}}' }}
    steps:
      - uses: actions/checkout@v6
      - name: Set lowercase container image
        run: echo "IMAGE=ghcr.io/${GITHUB_REPOSITORY,,}:$GITHUB_SHA" >> "$GITHUB_ENV"
      - uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ '{{' }} github.actor {{ '}}' }}
          password: ${{ '{{' }} secrets.GITHUB_TOKEN {{ '}}' }}
      - run: docker build -t "$IMAGE" .
      - run: docker push "$IMAGE"
      - id: image
        run: echo "reference=$IMAGE" >> "$GITHUB_OUTPUT"

{% if spec.deploy.enabled %}
  deploy:
    needs: docker
    runs-on: ubuntu-latest
    permissions:
      contents: read
{% if spec.deploy.platform == "gke" %}
      id-token: write
{% endif %}
    env:
      IMAGE: ${{ '{{' }} needs.docker.outputs.image {{ '}}' }}
      NAMESPACE: {{ spec.deploy.namespace }}
      APP_NAME: {{ spec.service.name }}
    steps:
      - uses: actions/checkout@v6
      - uses: azure/setup-kubectl@v4
{% if spec.deploy.platform == "gke" %}
      - uses: google-github-actions/auth@v3
        with:
          workload_identity_provider: ${{ '{{' }} secrets.GCP_WIF_PROVIDER {{ '}}' }}
          service_account: ${{ '{{' }} secrets.GCP_SERVICE_ACCOUNT {{ '}}' }}
          project_id: {{ spec.deploy.gcp_project }}
      - uses: google-github-actions/get-gke-credentials@v3
        with:
          cluster_name: {{ spec.deploy.cluster }}
          location: {{ spec.deploy.location }}
          project_id: {{ spec.deploy.gcp_project }}
{% else %}
      - name: Write kubeconfig
        env:
          KUBECONFIG_CONTENT: ${{ '{{' }} secrets.{{ spec.deploy.kubeconfig_secret }} {{ '}}' }}
        run: |
          if [ -z "$KUBECONFIG_CONTENT" ]; then
            echo "::error::Required GitHub Actions Secret {{ spec.deploy.kubeconfig_secret }} is missing or empty."
            exit 1
          fi
          mkdir -p "$HOME/.kube"
          printf '%s' "$KUBECONFIG_CONTENT" > "$HOME/.kube/config"
          chmod 600 "$HOME/.kube/config"
          kubectl config current-context
{% endif %}
      - run: kubectl config set-context --current --namespace="$NAMESPACE"
      - run: kubectl apply -f k8s/
      - run: kubectl set image deployment/$APP_NAME $APP_NAME=$IMAGE -n $NAMESPACE
      - run: kubectl rollout status deployment/$APP_NAME -n $NAMESPACE --timeout=180s
{% if spec.exposure.type == "ingress" %}
      - run: curl --fail --retry 10 --retry-delay 5 https://{{ spec.exposure.host }}{{ spec.exposure.health_path }}
{% elif spec.exposure.type == "loadBalancer" %}
      - run: kubectl get svc {{ spec.service.name }}-lb -n $NAMESPACE -o wide
{% else %}
      - run: kubectl run smoke --rm -i --restart=Never --image=curlimages/curl -- curl --fail http://{{ spec.service.name }}.{{ spec.deploy.namespace }}.svc.cluster.local{{ spec.exposure.health_path }}
{% endif %}
{% endif %}
